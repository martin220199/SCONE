type criticalKineticPhysicsPackage;


pop      1000; //20000
timeSteps   1000; 
XSdata   mg; 
dataType mg;
timeIncrement 1.0e-5;
cycles 5;
buffer 5000;
active   300;  //3000
inactive 100; //1000
combing 1;
plot 0;

criticalWgtNorm 1;
decorrelationCycles 100; //50
precursors 0;
kineticGeometry{enable 0;}


outputFormat asciiJSON;

collisionOperatorCritical { neutronMG {type neutronMGstd; precursors 0; couplingRatio 0.01;}} 
transportOperatorCritical { type transportOperatorDT;
                  }
collisionOperatorKinetic { neutronMG {type neutronMGkineticstd; precursors 0;}}

transportOperatorKinetic { type transportOperatorKineticDT;
}

tally  {
  flux_time { type collisionClerk; //collisionClerk_class, energyMap_class, scoreMemory_class
    map { type timeMap; grid lin; min 0.0; max 1e-2; N 1000;} 
    response (flux); flux {type fluxResponse;}
    }
  }

inactiveTally {
              }
activeTally  {
                display (k_eff);
                k_eff { type keffAnalogClerk;}
        }


geometry { 
  type geometryStd; 
  // ( -x, +x, -y, +y, -z, +z)
  boundary (0 0 0 0 1 1); 
  graph {type extended;}

  surfaces { 
             Domain          { id 3; type box; origin (0.0 0.0 0.0); halfwidth (53.55 53.55 32.13);}  
  }
  
  cells {  }
  
  universes { 
      root { id 1000; type rootUniverse; border 3; fill u<100>; }  
    
    // Pin universes 
    pin1 { id 1; type pinUniverse; radii (0.5400 0.0 ); fills (UO2 water);}
    pin2 { id 2; type pinUniverse; radii (0.5400 0.0 ); fills (GT water);}
    pin3 { id 3; type pinUniverse; radii (0.5400 0.0 ); fills (mox43 water);}
    pin4 { id 4; type pinUniverse; radii (0.5400 0.0 ); fills (mox7 water);}    
    pin5 { id 5; type pinUniverse; radii (0.5400 0.0 ); fills (mox87 water);}           
    pin6 { id 6; type pinUniverse; radii (0.5400 0.0 ); fills (FC water);}
    pin7 { id 7; type pinUniverse; radii (0.5400 0.0 ); fills (CR water);}
    // pin7 { id 7; type pinUniverse; radii (0.5400 0.581378 0.62 0.0 ); rotation (22.5 0 0);  fills (rod water);}

    // Infinite moderator
    pin30 { id 30; type pinUniverse; radii (0.0); fills (water);}      

    // Infinite void
    pin31 { id 31; type pinUniverse; radii (0.0); fills (mat_void);}      

