type criticalKineticPhysicsPackage;

pop      20000;
timeSteps   20; 
XSdata   ce;
dataType ce;
timeIncrement 1.0e-6;
cycles 5;
buffer 100000;
active   200;
inactive 200; 
combing 1;

decorrelationCycles 10;
precursors 1;

kineticGeometry{enable 1; timeSteps (8); }

outputFormat asciiJSON;
collisionOperatorCritical { neutronCE {type neutronCEstd; minEnergy 1.0e-11; maxEnergy 20; precursors 1; couplingRatio 0.0001;}} 

transportOperatorCritical { type transportOperatorDT;
                  }

collisionOperatorKinetic { neutronCE {type neutronCEkineticstd; minEnergy 1.0e-11; maxEnergy 20; precursors 1;}} //precursors 1;

transportOperatorKinetic { type transportOperatorKineticDT;
}


tally  {

  MGxss { type mgXsClerk;
      energyMap {type energyMap; grid predef; name ecco33; }
      spaceMap { type multiMap; maps (map1 map2); map1 {type homogMatMap; grid predef; bins (bin1 bin2 bin3 bin4); bin1 (IF); bin2 (OF); bin3 (DA); bin4 (CR);} map2 {type timeMap; grid lin; min 0.0; max 20.0e-6; N 20;}}
     }

  }




inactiveTally {
              }
activeTally  {
                display (k_eff);
                k_eff { type keffAnalogClerk;}

  flux_time { type collisionClerk; 
    map { type multiMap; maps (map1 map2);
      map1 { type spaceMap;  axis y;  grid lin; min -7.56; max 7.56; N 80;} 
      map2 { type spaceMap;  axis x;  grid lin;  min -7.56; max 7.56; N 80;}
    }
    response (flux); flux {type fluxResponse;}
    }
        }





