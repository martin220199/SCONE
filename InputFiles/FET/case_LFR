type criticalKineticPhysicsPackage;

pop      100000; //100000
timeSteps   100; // 100
XSdata   ce;
dataType ce;
timeIncrement 20.0e-6;
cycles 3;
buffer 100000;
active   100;
inactive 200;


combing 1;
precursors 1;
useForcedPrecursorDecay 1;
criticalWgtNorm 1;
kineticGeometry{enable 1; timeSteps (30); }
decorrelationCycles 50;


outputFormat asciiJSON;
collisionOperatorCritical { neutronCE {type neutronCEimp; minEnergy 1.0e-11; maxEnergy 20; precursors 1; couplingRatio 0.01;}}

transportOperatorCritical { type transportOperatorDT;
                  }

collisionOperatorKinetic { neutronCE {type neutronCEkineticimp; minEnergy 1.0e-11; maxEnergy 20; precursors 1;}}

transportOperatorKinetic { type transportOperatorKineticDT;
}

tally  {

  flux_time { type collisionClerk;

    map { type timeMap; grid lin; min 0.0; max 2000.0e-6; N 1000;} //N1000 high fidelity
    response (flux); flux {type fluxResponse;}

    }

  }

  inactiveTally {

  }
activeTally  {

    display (k_eff);
    k_eff { type keffAnalogClerk;}
}




